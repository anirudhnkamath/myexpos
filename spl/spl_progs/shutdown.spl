// switch stacks

alias userSP R1;
userSP = SP;

[PROCESS_TABLE + ([SYSTEM_STATUS_TABLE+1] * 16) + 13] = SP;
SP = [PROCESS_TABLE + ([SYSTEM_STATUS_TABLE+1] * 16) + 11]*512 - 1;


// ---------------------------------


// mode flag
[PROCESS_TABLE + ([SYSTEM_STATUS_TABLE+1] * 16 ) + 9] = INT_SHUTDOWN;


// ---------------------------------


// only shell process of root can call shutdown
if(([PROCESS_TABLE + ([SYSTEM_STATUS_TABLE + 1]*16) + 1] != 1) || ([PROCESS_TABLE + ([SYSTEM_STATUS_TABLE + 1]*16) + 3] != 1)) then

    // return failure
    [[PTBR + 2*((userSP - 1)/512)] * 512 + (userSP - 1) % 512] = -1;
    [PROCESS_TABLE + ([SYSTEM_STATUS_TABLE+1] * 16 ) + 9] = 0;
    SP = userSP;
    ireturn;
endif;

// ---------------------------------


// call KILLALL
R1 = KILL_ALL;
R2 = [SYSTEM_STATUS_TABLE + 1];
call PROCESS_MANAGER;


// ---------------------------------


// write back buffers if they are dirty
alias i R1;
i = 0;
while(i<4) do
    if([BUFFER_TABLE + i*4 + 1] == 1) then
        multipush(R1);
        R3 = BUFFER_BASE + i;
        R4 = [BUFFER_TABLE + i*4];
        R1 = DISK_STORE;
        R2 = [SYSTEM_STATUS_TABLE + 1];
        call DEVICE_MANAGER;
        multipop(R1);
    endif;

    i = i + 1;
endwhile;


// ---------------------------------


// write back inode table
multipush(R1);
R1 = DISK_STORE;
R2 = [SYSTEM_STATUS_TABLE + 1];
R3 = 59;    
R4 = 3; 
call DEVICE_MANAGER;
R1 = DISK_STORE;
R2 = [SYSTEM_STATUS_TABLE + 1];
R3 = 60;    
R4 = 4; 
call DEVICE_MANAGER;
multipop(R1);

// write back root file
multipush(R1);
R1 = DISK_STORE;
R2 = [SYSTEM_STATUS_TABLE + 1];
R3 = 62;    
R4 = 5; 
call DEVICE_MANAGER;
multipop(R1);

// write back disk free list
multipush(R1);
R1 = DISK_STORE;
R2 = [SYSTEM_STATUS_TABLE + 1];
R3 = 61;    
R4 = 2; 
call DEVICE_MANAGER;  
multipop(R1);  


// ---------------------------------


halt;