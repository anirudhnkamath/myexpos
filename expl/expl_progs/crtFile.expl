int main() {
    decl
        int temp,permission;
        string fileName;
    enddecl

    begin
        temp = exposcall("Read",-1,fileName);
        temp = exposcall("Read",-1,permission);

        temp=exposcall("Create",fileName,permission);

        if(temp == 0) then
            temp=exposcall("Write",-2,"Success");
        endif;

        return 0;
    end
}