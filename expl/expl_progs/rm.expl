int main(){
    decl 
        int fd,temp;
        string fileName;
    enddecl

    begin
        temp = exposcall("Write",-2,"FileName : ");
        temp = exposcall("Read",-1,fileName);

        temp = exposcall("Delete",fileName);

        if(temp == -1) then
            temp = exposcall("Write",-2,"noPermission");
        endif;
        return 0;
    end
}